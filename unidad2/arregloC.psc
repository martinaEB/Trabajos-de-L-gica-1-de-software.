Algoritmo arregloC
	dimensionar nombre[2]
	dimensionar edad[2]
	escribir"Ingrese su nombre: "
	leer nombre[1]
	escribir "Ingrese el nombre de su amiga/o: "
	leer nombre[2]
	escribir "Ingrese tu edad: "
	leer edad[1]
	escribir "Ingrese la edad de tu amiga/o: "
	leer edad[2]
	escribir "Sus nombres son: "
	escribir nombre[1]
	escribir nombre[2]
	escribir "La suma de sus edades es: "
	escribir edad[1]+edad[2]
FinAlgoritmo
